# AWS Credentials (REQUIRED)
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
# AWS_SESSION_TOKEN is OPTIONAL - only needed for temporary credentials (AWS SSO)
# AWS_SESSION_TOKEN=your_session_token_here

# S3 Configuration (REQUIRED)
S3_BUCKET_NAME=your-meetingmind-bucket

# Bedrock Configuration (REQUIRED for full functionality)
BEDROCK_KB_ID=your_knowledge_base_id
BEDROCK_DATA_SOURCE_ID=your_data_source_id
BEDROCK_AGENT_ID=your_agent_id

# Processing Configuration (OPTIONAL - defaults shown)
KEYFRAME_INTERVAL_SECONDS=20
PHASH_THRESHOLD=8
WHISPER_MODEL_SIZE=tiny

# Screen-Share Detection (OPTIONAL - defaults shown)
SCREENSHARE_ENABLED=true
SCREENSHARE_EDGE_DENSITY_MIN=0.15
SCREENSHARE_TEXT_REGION_MIN=3

# Chat Configuration (OPTIONAL - defaults shown)
MAX_CONVERSATION_HISTORY=10
